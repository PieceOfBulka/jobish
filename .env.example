DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me"
# AI-коуч через OpenRouter (без ключа — мок-движок). https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct"
# hh.ru официальный API (ФТ-3.1). Поиск вакансий публичный — токен не нужен.
# HH_ENABLED=1 включает живые запросы (нужен корректный User-Agent с контактом);
# пусто/0 — используется оценка по сид-данным. https://api.hh.ru/openapi/redoc
HH_ENABLED=""
HH_USER_AGENT="Jobish/1.0 (your-email@example.com)"
