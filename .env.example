DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me"
# AI-коуч через OpenRouter (без ключа — мок-движок). https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct"
# hh.ru официальный API (ФТ-3.1). Токен берётся автоматически (client_credentials)
# вместе с обязательным User-Agent. Создать приложение: https://dev.hh.ru/admin
# HH_ENABLED=1 + client_credentials → живые данные; пусто — оценка по сид-данным.
# HH_ACCESS_TOKEN — необязательный override готовым токеном.
HH_ENABLED=""
HH_USER_AGENT="Jobish/1.0 (your-email@example.com)"
HH_ACCESS_TOKEN=""
HH_CLIENT_ID=""
HH_CLIENT_SECRET=""
