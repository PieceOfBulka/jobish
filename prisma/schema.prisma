// Jobish — логическая модель данных (MVP, клиентский срез)
// См. docs/architecture.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────── Пользователь и профиль ───────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  passwordAlgo      String    @default("bcrypt") // bcrypt | argon2 | pbkdf2
  passwordUpdatedAt DateTime  @default(now())
  name              String
  role              String    @default("client") // client | coach | admin (ФТ-1.5)
  isVerified        Boolean   @default(false) // ФТ-1.6
  isBlocked         Boolean   @default(false) // US17 модерация
  verificationCode  String? // одноразовый код подтверждения почты
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile      Profile?
  orientation  OrientationResult?
  careerGoals  CareerGoal[]
  roadmaps     Roadmap[]
  attempts     TheoryAttempt[]
  chatSessions ChatSession[]
  subscription Subscription?
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ФТ-1.2 / ФТ-1.3 — наполнение профиля (логическая модель данных v2)
  telegramNick      String? // опц., начинается с «@»
  age               Int? // опц., 0..150
  experienceMonths  Int     @default(0) // опыт в месяцах, 0..1000
  educationPlace    String? // вуз/колледж
  gradeLevel        String? // enum уровня образования
  currentSpecialty  String? // текущая специальность
  currentPosition   String? // Junior|Middle|Senior|Lead|Head|Другое
  preparationLevel  String? // Студент|Выпускник|Джун
  salaryExpectation Int? // ожидаемая ЗП
  skills            String? // JSON-массив тегов навыков
  desiredSpheres    String? // JSON-массив желаемых сфер
  bio               String?
  targetProfession  String? // slug выбранной целевой профессии
  resumeFileName    String? // имя файла резюме (ФТ-1.4, мок хранилища)

  streakDays Int       @default(0) // мотивация: ежедневная привычка (ФТ-7)
  lastVisit  DateTime?
  updatedAt  DateTime  @updatedAt
}

// Заявки в поддержку (NFR_SP3)
model SupportTicket {
  id        String   @id @default(cuid())
  email     String
  subject   String
  message   String
  status    String   @default("open") // open | answered | closed
  createdAt DateTime @default(now())
}

// ─────────────── Справочник профессий ───────────────

model Profession {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  category    String
  summary     String
  description String

  // ФТ-3.1 — разделы сводки рынка
  responsibilities String? // JSON: ключевые обязанности
  typicalDay       String? // типичный рабочий день
  transitionMonths Int? // ожидаемое время освоения (мес.)
  transitionNote   String? // финансовый мост / рекомендация по переходу
  tasks            String? // JSON: типичные задачи
  cases            String? // JSON: [{title, url}] кейсы/датасеты для портфолио

  skills      ProfessionSkill[]
  market      MarketAnalytics?
  materials   LearningMaterial[]
  theoryTests TheoryTest[]
  vacancies   Vacancy[]
}

// Вакансии (ФТ-3.2 / ФТ-3.3) — внутренняя база (источник: офиц. API hh.ru / моки)
model Vacancy {
  id           String     @id @default(cuid())
  professionId String
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  title        String
  company      String
  city         String
  format       String // remote | hybrid | office
  salaryMin    Int
  salaryMax    Int
  experience   Int // требуемый опыт, лет
  employment   String // full | part | project
  url          String     @default("")
  createdAt    DateTime   @default(now())
}

model ProfessionSkill {
  id           String     @id @default(cuid())
  professionId String
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  name         String
  type         String     // hard | soft
  grade        String     // junior | middle | senior
  order        Int        @default(0)
}

// Аналитика рынка труда (US6, ФТ-3) — сид-данные
model MarketAnalytics {
  id            String     @id @default(cuid())
  professionId  String     @unique
  profession    Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  demandLevel   String     // низкая | средняя | высокая
  openVacancies Int
  salaryJunior  Int
  salaryMiddle  Int
  salarySenior  Int
  salaryTrend   String     // JSON: [{month, junior, middle, senior}]
  topCompanies  String     // JSON: [{name, salary, hiring}]
  source        String
  updatedAt     DateTime   @default(now())
}

// Рекомендованные обучающие материалы (US1, ФТ-5)
model LearningMaterial {
  id           String     @id @default(cuid())
  professionId String
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  skillName    String
  title        String
  url          String
  provider     String
  isFree       Boolean    @default(true)
}

// ─────────────── Карьерные цели (US9) ───────────────

model CareerGoal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  horizon   String
  rationale String
  createdAt DateTime @default(now())
}

// ─────────────── Roadmap / карта развития (US1,2,3, ФТ-3,4) ───────────────

model Roadmap {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  professionSlug String
  title          String
  currentStatus  String? // ФТ-4.1: где пользователь сейчас (4-5 предложений)
  targetStatus   String? // ФТ-4.1: к чему придёт после всех этапов
  createdAt      DateTime       @default(now())
  stages         RoadmapStage[]
}

model RoadmapStage {
  id        String        @id @default(cuid())
  roadmapId String
  roadmap   Roadmap       @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  steps     RoadmapStep[]
}

model RoadmapStep {
  id            String       @id @default(cuid())
  stageId       String
  stage         RoadmapStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  skillName     String
  status        String       @default("not_started") // not_started | in_progress | done
  // ФТ-4.1 — источник обучения и сроки
  materialUrl      String?
  materialTitle    String?
  materialAuthor   String? // автор/провайдер
  materialType     String? // статья | онлайн-курс | видео
  materialDuration Int? // примерная длительность, мин
  materialRating   Float? // рейтинг из интернета
  estimateHours    Int? // примерные сроки освоения, ч
  order            Int     @default(0)
}

// ─────────────── Профориентационный тест (US4,5) ───────────────

model OrientationResult {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    String   // JSON ответов
  scores     String   // JSON: соответствие по категориям
  topMatches String   // JSON: [{slug, title, match}]
  createdAt  DateTime @default(now())
}

// ─────────────── Теоретические тесты (US7, ФТ-4) ───────────────

model TheoryTest {
  id           String           @id @default(cuid())
  professionId String
  profession   Profession       @relation(fields: [professionId], references: [id], onDelete: Cascade)
  title        String
  topic        String
  questions    TheoryQuestion[]
  attempts     TheoryAttempt[]
}

model TheoryQuestion {
  id      String     @id @default(cuid())
  testId  String
  test    TheoryTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  text    String
  options String     // JSON массив вариантов
  correct Int        // индекс правильного варианта
  topic   String
  order   Int        @default(0)
}

// Попытка с механикой "заморозки" при неудаче
model TheoryAttempt {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        TheoryTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  score       Int        // % правильных
  passed      Boolean
  weakTopics  String     // JSON список слабых тем
  frozenUntil DateTime?  // заморозка перепрохождения
  extraTries  Int        @default(0)
  createdAt   DateTime   @default(now())
}

// ─────────────── AI-чат-коуч (ФТ-1,2,6; US8,9,10) ───────────────

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("Новый диалог")
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // user | assistant
  content   String
  createdAt DateTime    @default(now())
}

// ─────────────── Подписка (мок монетизации) ───────────────

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      String    @default("free") // free | start | optimal | pro
  status    String    @default("active")
  startedAt DateTime  @default(now())
  expiresAt DateTime?
}
